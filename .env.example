# ============================================================================
# MeritCoin — Variables de entorno
# Copia este archivo:  cp .env.example .env
# ============================================================================

# ── Moodle ──────────────────────────────────────────────────────────────────
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=Admin1234!   # ⚠️ CAMBIA esto antes de producción
MOODLE_ADMIN_EMAIL=admin@meritcoin.local
MOODLE_PORT=8080
MOODLE_HTTPS_PORT=8443

# ── MariaDB (Moodle) ───────────────────────────────────────────────────────
MOODLE_DB_USER=bn_moodle
MOODLE_DB_PASSWORD=moodle_pass     # ⚠️ CAMBIA esto antes de producción
MOODLE_DB_NAME=bitnami_moodle
MARIADB_ROOT_PASSWORD=root_pass    # ⚠️ CAMBIA esto antes de producción

# ── PostgreSQL (Backend FastAPI) ───────────────────────────────────────────
PG_USER=meritcoin
PG_PASSWORD=meritcoin_pass         # ⚠️ CAMBIA esto antes de producción
PG_DB=meritcoin_db
PG_PORT=5432
DATABASE_URL=postgresql+asyncpg://meritcoin:meritcoin_pass@postgres:5432/meritcoin_db

# ── FastAPI Backend ────────────────────────────────────────────────────────
FASTAPI_PORT=8000
HMAC_SECRET=cambia-este-secreto-en-produccion   # ⚠️ CAMBIA esto antes de producción
DEBUG=true

# ── Blockchain (Besu) ──────────────────────────────────────────────────
# Besu local node por defecto expone en http://127.0.0.1:8545
BLOCKCHAIN_RPC_URL=http://host.docker.internal:8545
# Cuenta deployer (IMPORTANTE: Esta es una clave de EJEMPLO, usar la real en .env)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Direcciones de contratos desplegados (actualizar después del deploy)
BADGE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
MRT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Wallets custodiales ────────────────────────────────────────────────────────
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ OBLIGATORIO para el sistema de wallets — sin esto el backend no arranca
WALLET_ENCRYPTION_KEY=tu-clave-fernet-aqui

# ── IPFS ───────────────────────────────────────────────────────────────
IPFS_API_URL=http://ipfs:5001
IPFS_GATEWAY_URL=http://localhost:8090